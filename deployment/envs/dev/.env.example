# Fikua Lab — VPS environment variables
# Copy to .env and fill in real values

# Docker image
DOCKER_REGISTRY=oriolcanades
FIKUA_VERSION=latest

# Database
FIKUA_POSTGRES_USER=fikua
FIKUA_POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Docker Hub credentials (for pulling private image)
DOCKER_USERNAME=oriolcanades
DOCKER_PAT=CHANGE_ME_DOCKERHUB_PAT
